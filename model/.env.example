# 环境变量配置文件示例
# 复制此文件为 .env 并填入真实的API密钥

# =========================
# 必需配置
# =========================

# 阿里云百炼API密钥（必需）
# 获取方式：访问 https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# JWT密钥（必需，用于API认证）
# 建议使用随机字符串，至少32位
SECRET_KEY=your-secret-key-here-change-this-to-random-string

# =========================
# 可选配置
# =========================

# HuggingFace镜像地址（可选，用于加速模型下载）
HF_ENDPOINT=https://hf-mirror.com

# =========================
# 模型配置（可选）
# =========================

# 使用的模型（默认使用qwen系列）
# 可选值：qwen-max, qwen-plus, qwen-turbo
MODEL_NAME=qwen-max

# API基础URL（默认使用阿里云兼容模式）
API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =========================
# 服务配置（可选）
# =========================

# 服务端口（默认8000）
PORT=8000

# 服务主机（默认0.0.0.0）
HOST=0.0.0.0

# 日志级别（可选：DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# =========================
# 数据库配置（可选）
# =========================

# ChromaDB持久化目录（默认./chroma_db_unified）
CHROMA_PERSIST_DIR=./chroma_db_unified

# =========================
# 性能配置（可选）
# =========================

# 最大工作线程数（默认10）
MAX_WORKERS=10

# 请求超时时间（秒，默认300）
REQUEST_TIMEOUT=300

# =========================
# 功能开关（可选）
# =========================

# 是否启用影像识别（默认true）
ENABLE_VISION=true

# 是否启用PubMed检索（默认true）
ENABLE_PUBMED=true

# 是否启用健康风险分析（默认true）
ENABLE_HEALTH_ANALYSIS=true